          <span class="font-semibold text-sm">Docker</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="funcionalidades" class="py-32 bg-slate-950">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20 reveal">
        <span class="inline-block px-4 py-1.5 rounded-full bg-cyan-500/10 text-cyan-400 text-sm font-medium mb-4">Funcionalidades</span>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6">Tudo que voce precisa</h2>
        <p class="text-slate-400 max-w-2xl mx-auto text-lg">
          Automacao completa do ciclo de desenvolvimento com inteligencia artificial.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Monitoramento 24/7</h3>
          <p class="text-slate-400 leading-relaxed">
            Detecta novas issues automaticamente via cron job configuravel. Zero intervencao manual.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-cyan-500 to-teal-500 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Copilot Nativo</h3>
          <p class="text-slate-400 leading-relaxed">
            Integra diretamente com GitHub Copilot Agent. Issues viram PRs com codigo funcional.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-cyan-500 to-blue-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Sync Bidirecional</h3>
          <p class="text-slate-400 leading-relaxed">
            Status e progresso atualizados automaticamente no sistema de origem conforme o PR evolui.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Dashboard Moderno</h3>
          <p class="text-slate-400 leading-relaxed">
            Interface web completa para visualizar e gerenciar todas as atividades em tempo real.
          </p>
        </div>

        <!-- Feature 5 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-red-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Labels Inteligentes</h3>
          <p class="text-slate-400 leading-relaxed">
            Aplica labels no GitHub automaticamente baseado no tracker e titulo da issue.
          </p>
        </div>

        <!-- Feature 6 -->
        <div class="feature-card bg-gradient-to-br from-slate-800/50 to-slate-900/50 rounded-2xl p-8 border border-white/5 reveal">
          <div class="w-14 h-14 bg-gradient-to-br from-yellow-500 to-orange-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Seguranca Total</h3>
          <p class="text-slate-400 leading-relaxed">
            OAuth ou PAT com criptografia AES-256. Seus tokens sempre protegidos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it Works Section -->
  <section id="como-funciona" class="py-32 bg-slate-900">
    <div class="container mx-auto px-6">
      <div class="text-center mb-20 reveal">
        <span class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-sm font-medium mb-4">Processo</span>
        <h2 class="text-4xl lg:text-5xl font-bold mb-6">Como Funciona</h2>
        <p class="text-slate-400 max-w-2xl mx-auto text-lg">
          Um fluxo simples e 100% automatizado do inicio ao fim.
        </p>
      </div>

      <!-- Flow Steps -->
      <div class="grid md:grid-cols-4 gap-6 mb-20">
        <div class="flow-connector text-center reveal">
          <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl flex items-center justify-center shadow-xl glow-purple">
            <span class="text-3xl font-black text-white">1</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Issue Criada</h3>
          <p class="text-slate-400 text-sm">Nova tarefa no sistema de origem</p>
        </div>

        <div class="flow-connector text-center reveal">
          <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center shadow-xl">
            <span class="text-3xl font-black text-white">2</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Detectada</h3>
          <p class="text-slate-400 text-sm">Sistema cria issue no GitHub para o Copilot</p>
        </div>

        <div class="flow-connector text-center reveal">
          <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-teal-500 to-teal-600 rounded-2xl flex items-center justify-center shadow-xl">
            <span class="text-3xl font-black text-white">3</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Desenvolvida</h3>
          <p class="text-slate-400 text-sm">Copilot cria PR com a implementacao</p>
        </div>

        <div class="text-center reveal">
          <div class="w-20 h-20 mx-auto mb-6 bg-gradient-to-br from-emerald-500 to-emerald-700 rounded-2xl flex items-center justify-center shadow-xl glow-green">
            <span class="text-3xl font-black text-white">4</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Sincronizada</h3>
          <p class="text-slate-400 text-sm">Sistema de origem atualizado automaticamente</p>
        </div>
      </div>

      <!-- Lifecycle Table -->
      <div class="max-w-5xl mx-auto reveal">
        <div class="bg-slate-800/50 rounded-3xl p-8 lg:p-10 border border-white/5 overflow-hidden">
          <h3 class="text-2xl font-bold mb-8 text-center">Ciclo de Vida da Issue</h3>
          <div class="overflow-x-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-white/10">
                  <th class="text-left py-4 px-4 text-slate-400 font-medium">Evento</th>
                  <th class="text-left py-4 px-4 text-slate-400 font-medium">GitHub</th>
                  <th class="text-left py-4 px-4 text-slate-400 font-medium">Origem</th>
                  <th class="text-center py-4 px-4 text-slate-400 font-medium">Progresso</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="py-4 px-4 font-medium">Issue detectada</td>
                  <td class="py-4 px-4 text-slate-400">Cria issue para Copilot</td>
                  <td class="py-4 px-4"><span class="badge bg-blue-500/20 text-blue-400 border-0">Em Andamento</span></td>
                  <td class="py-4 px-4 text-center">
                    <div class="radial-progress text-cyan-400 text-xs" style="--value:20; --size:2.5rem; --thickness:3px;">20%</div>
                  </td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="py-4 px-4 font-medium">PR aberto</td>
                  <td class="py-4 px-4 text-slate-400">Copilot inicia desenvolvimento</td>
                  <td class="py-4 px-4"><span class="badge bg-blue-500/20 text-blue-400 border-0">Em Andamento</span></td>
                  <td class="py-4 px-4 text-center">
                    <div class="radial-progress text-cyan-400 text-xs" style="--value:40; --size:2.5rem; --thickness:3px;">40%</div>
                  </td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="py-4 px-4 font-medium">PR com 2+ commits</td>
                  <td class="py-4 px-4 text-slate-400">Aguardando revisao</td>
                  <td class="py-4 px-4"><span class="badge bg-yellow-500/20 text-yellow-400 border-0">Resolvida</span></td>
                  <td class="py-4 px-4 text-center">
                    <div class="radial-progress text-yellow-400 text-xs" style="--value:80; --size:2.5rem; --thickness:3px;">80%</div>
                  </td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="py-4 px-4 font-medium">PR merged</td>
                  <td class="py-4 px-4 text-slate-400">Codigo integrado</td>
                  <td class="py-4 px-4"><span class="badge bg-emerald-500/20 text-emerald-400 border-0">Resolvida</span></td>
                  <td class="py-4 px-4 text-center">
                    <div class="radial-progress text-emerald-400 text-xs" style="--value:100; --size:2.5rem; --thickness:3px;">100%</div>
                  </td>
                </tr>
                <tr class="hover:bg-white/5 transition-colors">
                  <td class="py-4 px-4 font-medium">PR fechado</td>
                  <td class="py-4 px-4 text-slate-400">Rejeitado sem merge</td>
                  <td class="py-4 px-4"><span class="badge bg-red-500/20 text-red-400 border-0">Rejeitada</span></td>
                  <td class="py-4 px-4 text-center text-slate-500">-</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Demo Section -->
  <section id="demo" class="py-32 bg-slate-950">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="reveal">
          <span class="inline-block px-4 py-1.5 rounded-full bg-emerald-500/10 text-emerald-400 text-sm font-medium mb-4">Conecte</span>
          <h2 class="text-4xl lg:text-5xl font-bold mb-6">Conecte suas ferramentas</h2>
          <p class="text-slate-400 text-lg mb-8 leading-relaxed">
            Conecte seu sistema de tarefas favorito ao GitHub. Configure uma vez e deixe a IA trabalhar por voce.
          </p>

          <div class="space-y-6">
            <!-- Sistema de Origem -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-800/50 border border-white/5">
              <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-cyan-500 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold mb-1">Seu Sistema de Tarefas</h4>
                <p class="text-slate-400 text-sm">Redmine,Conecte via API.</p>
              </div>
            </div>

            <!-- GitHub -->
            <div class="flex items-start gap-4 p-4 rounded-xl bg-slate-800/50 border border-white/5">
              <div class="w-12 h-12 bg-slate-700 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </div>
              <div>
                <h4 class="font-semibold mb-1">GitHub + Copilot</h4>
                <p class="text-slate-400 text-sm">Cria issues, monitora PRs, sincroniza forks e aplica labels</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Code Preview -->
        <div class="reveal">
          <div class="terminal rounded-2xl overflow-hidden shadow-2xl">
            <div class="terminal-header px-4 py-3 flex items-center gap-2">
              <div class="w-3 h-3 rounded-full bg-red-500"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
              <div class="w-3 h-3 rounded-full bg-green-500"></div>
              <span class="ml-4 text-sm text-slate-400">.env</span>
            </div>
            <div class="p-6 text-sm font-mono leading-relaxed">
              <div class="text-slate-500"># Servidor</div>
              <div><span class="text-purple-400">PORT</span>=<span class="text-emerald-400">3000</span></div>
              <div><span class="text-purple-400">NODE_ENV</span>=<span class="text-emerald-400">production</span></div>
              <div class="mt-4 text-slate-500"># Sistema de Origem</div>
              <div><span class="text-purple-400">SOURCE_URL</span>=<span class="text-emerald-400">https://tasks.empresa.com</span></div>
              <div><span class="text-purple-400">SOURCE_API_KEY</span>=<span class="text-emerald-400">sua_api_key</span></div>
              <div class="mt-4 text-slate-500"># GitHub OAuth</div>
              <div><span class="text-purple-400">GITHUB_CLIENT_ID</span>=<span class="text-emerald-400">seu_client_id</span></div>
              <div><span class="text-purple-400">GITHUB_CLIENT_SECRET</span>=<span class="text-emerald-400">seu_client_secret</span></div>
              <div class="mt-4 text-slate-500"># Cron (a cada minuto)</div>
              <div><span class="text-purple-400">CRON_INTERVAL</span>=<span class="text-emerald-400">* * * * *</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 cta-gradient relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    </div>
    <div class="container mx-auto px-6 text-center relative z-10">
      <h2 class="text-4xl lg:text-6xl font-black text-white mb-6">
        Pronto para automatizar?
      </h2>
      <p class="text-white/80 max-w-2xl mx-auto mb-12 text-xl">
        Comece em minutos. Issues viram codigo enquanto voce toma um cafe.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="https://github.com/infraestrutura-inovare/redmine-automate" target="_blank" class="btn btn-lg bg-white text-emerald-700 hover:bg-slate-100 border-0 font-bold px-10 shadow-xl">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Ver no GitHub
        </a>
        <a href="https://github.com/infraestrutura-inovare/redmine-automate#como-rodar-localmente" target="_blank" class="btn btn-lg btn-outline border-white/40 text-white hover:bg-white/10 hover:border-white font-bold px-10">
          Ler Documentacao
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 bg-slate-950 border-t border-white/5">
    <div class="container mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-2">
          <svg class="w-8 h-8" viewBox="0 0 30 50" fill="none" stroke="url(#footerGradient)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <defs>
              <linearGradient id="footerGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" style="stop-color:#3B82F6"/>
                <stop offset="50%" style="stop-color:#06B6D4"/>
                <stop offset="100%" style="stop-color:#10B981"/>
              </linearGradient>
            </defs>
            <path d="M8 14 L2 25 L8 36"/>
            <path d="M22 14 L28 25 L22 36"/>
          </svg>
          <span class="text-lg">
            <span class="font-normal bg-gradient-to-r from-blue-500 via-cyan-500 to-emerald-500 bg-clip-text text-transparent">Air</span><span class="font-bold text-slate-300">Code</span>
          </span>
        </div>
        <p class="text-slate-500 text-sm">MIT License - 2024</p>
        <a href="https://github.com/infraestrutura-inovare/redmine-automate" target="_blank" class="btn btn-ghost btn-circle text-slate-400 hover:text-white">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        </a>
      </div>
    </div>
  </footer>

  <script>
    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const revealOnScroll = () => {
      reveals.forEach(el => {
        const windowHeight = window.innerHeight;
        const revealTop = el.getBoundingClientRect().top;
        const revealPoint = 150;
        if (revealTop < windowHeight - revealPoint) {
          el.classList.add('active');
        }
      });
    };
    window.addEventListener('scroll', revealOnScroll);
    revealOnScroll();
  </script>
</body>
</html>
